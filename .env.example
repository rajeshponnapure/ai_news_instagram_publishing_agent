[TEMPLATE - GitHub Actions Only]
# Copy these values to GitHub repository Secrets (Settings -> Secrets and variables -> Actions).
# The agent runs exclusively in GitHub Actions and ignores .env for CLI runs.

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password
EMAIL_SENDER_FILTER=grdevelopers.co@gmail.com
EMAIL_FOLDER=INBOX

# PROCESS_ALL_MATCHING=false only processes new mail. Use true only for a one-time backfill.
PROCESS_ALL_MATCHING=false
LOOKBACK_HOURS=48
MAX_EMAILS_PER_RUN=5

# auto uses Gemini when GEMINI_API_KEY is present, then Ollama, then local fallback.
SUMMARY_PROVIDER=auto
GEMINI_API_KEY=AQ.Ab8RN6JpM3vBQ_gvhFIRT_ozxNa2FWC5eSMJn06_LQJbbicuYg
GEMINI_MODEL=gemini-2.5-flash

DB_PATH=data/agent.sqlite3
REPORTS_DIR=reports
INSTAGRAM_DIR=reports/instagram_posts
CREATE_INSTAGRAM_POSTS=true

# Article enrichment opens the links inside each email, extracts article text,
# and downloads the article image for the carousel design.
ENRICH_ARTICLES=true
MAX_ARTICLE_LINKS_PER_EMAIL=0
ARTICLE_ASSETS_DIR=data/article_assets

# Auto-publishing requires an Instagram Business/Creator account, a Meta app,
# instagram_content_publish permission, and public URLs for the generated PNGs.
# In GitHub Actions, set this to:
# https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPOSITORY/instagram_posts
AUTO_PUBLISH_INSTAGRAM=false
PUBLIC_MEDIA_BASE_URL=
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_API_VERSION=v24.0

# Optional Facebook Page publishing. Use the connected Facebook Page ID and
# a Page access token with pages_manage_posts permission.
AUTO_PUBLISH_FACEBOOK=false
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# ── Memory & Dedup (cross-cycle) ─────────────────────────────────────────────
# ENABLE_MEMORY=true stores article SHA-256 / SimHash fingerprints in SQLite.
# ENABLE_DEDUP=true rejects exact and near-duplicate stories across runs.
# Duplicate threshold: ≥ 0.92 = same story; 0.82–0.92 = near-dup clustered.
ENABLE_MEMORY=true
ENABLE_DEDUP=true
SIMILARITY_DUP_THRESHOLD=0.92
SIMILARITY_CLUSTER_THRESHOLD=0.82

# ── Verification (two-phase quality gate) ────────────────────────────────────
# Pre-generation (per-article) + pre-publish (per-carousel) checks.
# 0.85 = minimum confidence to pass; MAX_VERIFICATION_ROUNDS=2 repair attempts.
ENABLE_VERIFICATION=true
VERIFICATION_CONFIDENCE_THRESHOLD=0.85
MAX_VERIFICATION_ROUNDS=2

# ── Post Planner ─────────────────────────────────────────────────────────────
# POST_SIZE=8 enforces exactly-8 article carousels (surplus queued for next run).
POST_SIZE=8

# ── LLM provider ─────────────────────────────────────────────────────────────
# SUMMARY_PROVIDER=local uses the built-in zero-dependency NLP summarizer.
# SUMMARY_PROVIDER=gemini requires GEMINI_API_KEY and GEMINI_MODEL.
# SUMMARY_PROVIDER=ollama requires OLLAMA_URL and OLLAMA_MODEL.
POLL_INTERVAL_MINUTES=1
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
